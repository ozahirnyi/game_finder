RAWG_API_KEY=change-me
RAWG_TIMEOUT_SECONDS=12
STEAM_API_KEY=change-me
ITAD_API_KEY=change-me
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_BOT_USERNAME=change-me
TELEGRAM_WEBHOOK_SECRET=change-me
PRICE_ALERT_WATCHER_ENABLED=false
PRICE_ALERT_INTERVAL_SECONDS=86400
PRICE_ALERT_INITIAL_DELAY_SECONDS=60
PRICE_ALERT_MIN_CUT=1
STEAM_SOCIAL_REFRESH_STALE_MINUTES=60
STEAM_SOCIAL_REFRESH_BATCH_SIZE=25
STEAM_SOCIAL_REFRESH_INTERVAL_SECONDS=300


SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Local Docker Compose values. In Railway, use the PostgreSQL/Redis service
# connection variables instead of these hostnames.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/gamefinder
REDIS_URL=redis://redis:6379/0


OPENAI_API_KEY=change-me
OPENAI_TIMEOUT_SECONDS=8
AI_FALLBACK_ENABLED=true


FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000
FRONTEND_PUBLIC_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000
# Railway injects RAILWAY_PUBLIC_DOMAIN for the backend service. Do not set it
# locally; set BACKEND_PUBLIC_URL to that backend's generated public URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
